# Copy this file to .env.local and fill in your values

# Database - PostgreSQL connection strings
# For Supabase pooler in local dev, use a higher connection_limit than 1 to avoid pool timeouts.
DATABASE_URL="postgresql://username:password@localhost:5432/diag_ops?connection_limit=5&pool_timeout=30"
DIRECT_URL="postgresql://username:password@localhost:5432/diag_ops"

# NextAuth
AUTH_SECRET="your-super-secret-key-here-change-this"
NEXTAUTH_URL="https://diagsync.vercel.app"

# App
NEXT_PUBLIC_APP_NAME="DiagOps"
NEXT_PUBLIC_APP_URL="https://diagsync.vercel.app"

# Platform mega admin bootstrap (seed only)
mega_ADMIN_EMAIL="admin@diagsync.com"
mega_ADMIN_PASSWORD="change-this-password"
mega_ADMIN_NAME="DiagSync Admin"

# Web Push (service worker push notifications)
# Generate once with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# Cloudinary signed upload (server-side only)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
